{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@devstone/configs-typescript/base.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "webworker"
    ],
    "types": [
      "@cloudflare/workers-types"
    ],
    "noEmit": true
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../../packages/configs/eslint"
    },
    {
      "path": "../../packages/configs/typescript"
    }
  ]
}
