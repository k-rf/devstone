{
  "$schema": "https://raw.githubusercontent.com/evilmartians/lefthook/refs/heads/master/schema.json",

  "pre-commit": {
    "commands": {
      "lint-staged": {
        "run": "pnpm lint-staged"
      }
    }
  },
  "commit-msg": {
    "commands": {
      "commitlint": {
        "run": "pnpm commitlint --config packages/configs/commitlint/src/commitlint.config.ts --edit {1}"
      }
    }
  }
}
