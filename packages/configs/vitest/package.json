{
  "name": "@devstone/configs-vitest",
  "version": "1.0.0",
  "private": true,
  "description": "Vitestの設定をまとめたパッケージです。",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./base": {
      "types": "./dist/configs/base.d.ts",
      "dev": "./src/configs/base.ts",
      "default": "./dist/configs/base.js"
    },
    "./ui": {
      "types": "./dist/configs/ui.d.ts",
      "dev": "./src/configs/ui.ts",
      "default": "./dist/configs/ui.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo -p tsconfig.check.json",
    "lint": "eslint --fix"
  },
  "devDependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-bun": "0.89.0",
    "@effect/platform-node": "0.106.0",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "@vitest/coverage-istanbul": "4.1.5",
    "effect": "3.21.2",
    "eslint": "10.2.1",
    "nyc": "18.0.0",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "@vitest/coverage-istanbul": ">=4.0.0",
    "vitest": ">=4.0.0"
  }
}
