{
  "name": "@devstone/configs-eslint",
  "version": "1.0.0",
  "private": true,
  "description": "ESLintの設定をまとめたパッケージです。",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "dev": "./src/base.ts",
      "default": "./dist/base.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "dev": "./src/react.ts",
      "default": "./dist/react.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "dev": "./src/node.ts",
      "default": "./dist/node.js"
    },
    "./cspell": {
      "types": "./dist/cspell.d.ts",
      "dev": "./src/cspell.ts",
      "default": "./dist/cspell.js"
    },
    "./import": {
      "types": "./dist/import.d.ts",
      "dev": "./src/import.ts",
      "default": "./dist/import.js"
    },
    "./sonarjs": {
      "types": "./dist/sonarjs.d.ts",
      "dev": "./src/sonarjs.ts",
      "default": "./dist/sonarjs.js"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "dev": "./src/css.ts",
      "default": "./dist/css.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "dev": "./src/markdown.ts",
      "default": "./dist/markdown.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "dev": "./src/json.ts",
      "default": "./dist/json.js"
    },
    "./unicorn": {
      "types": "./dist/unicorn.d.ts",
      "dev": "./src/unicorn.ts",
      "default": "./dist/unicorn.js"
    },
    "./jsdoc": {
      "types": "./dist/jsdoc.d.ts",
      "dev": "./src/jsdoc.ts",
      "default": "./dist/jsdoc.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo -p tsconfig.check.json",
    "lint": "eslint --fix"
  },
  "dependencies": {
    "@cspell/eslint-plugin": "10.0.0",
    "@eslint/css": "1.1.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "8.0.1",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.5.0",
    "typescript-eslint": "8.59.1"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "eslint": "10.2.1"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  }
}
