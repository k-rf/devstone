{
  "name": "Branch naming convention",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": [
        "refs/heads/main",
        "refs/heads/feature/DEV-[0-9]*/*",
        "refs/heads/fix/DEV-[0-9]*/*",
        "refs/heads/chore/DEV-[0-9]*/*",
        "refs/heads/docs/DEV-[0-9]*/*",
        "refs/heads/refactor/DEV-[0-9]*/*",
        "refs/heads/hotfix/DEV-[0-9]*/*",
        "refs/heads/test/DEV-[0-9]*/*",
        "refs/heads/ci/DEV-[0-9]*/*",
        "refs/heads/release/DEV-[0-9]*/*",
        "refs/heads/cursor/feature/DEV-[0-9]*/*",
        "refs/heads/cursor/fix/DEV-[0-9]*/*",
        "refs/heads/cursor/chore/DEV-[0-9]*/*",
        "refs/heads/cursor/docs/DEV-[0-9]*/*",
        "refs/heads/cursor/refactor/DEV-[0-9]*/*",
        "refs/heads/cursor/hotfix/DEV-[0-9]*/*",
        "refs/heads/cursor/test/DEV-[0-9]*/*",
        "refs/heads/cursor/ci/DEV-[0-9]*/*",
        "refs/heads/cursor/release/DEV-[0-9]*/*",
        "refs/heads/dependabot/*/*"
      ]
    }
  },
  "rules": [{ "type": "creation" }, { "type": "update" }]
}
