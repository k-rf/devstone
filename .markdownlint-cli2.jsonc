{
  "config": {
    "line-length": {
      "line_length": 100,
      "tables": false,
      "code_blocks": false,
      "strict": false
    }
  },
  "gitignore": true,
  "ignores": [
    ".git/**",
    "CLAUDE.md",
    "**/.claude/skills/**/FORMS.md",
    "**/build/**",
    "**/dist/**",
    "**/node_modules/**"
  ]
}
