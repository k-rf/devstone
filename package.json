{
  "name": "devstone",
  "version": "0.0.1",
  "private": true,
  "description": "自作のライブラリやツールを集めたモノレポです。",
  "license": "MIT",
  "author": {
    "name": "Kawano Kenichi",
    "email": "kenichi.k.820@gmail.com",
    "url": "https://github.com/k-rf"
  },
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsgo -p tsconfig.check.json",
    "format": "oxfmt",
    "lint": "eslint --fix --max-warnings 0",
    "lint:md": "markdownlint-cli2 --fix '**/*.md'",
    "knip": "knip",
    "test:cov": "moon run configs-vitest:coverage-report",
    "check:all": "moon r :format && moon r :typecheck && moon r :lint && pnpm run lint:md && moon r :knip && pnpm run test:cov"
  },
  "devDependencies": {
    "@devstone/configs-eslint": "workspace:*",
    "@devstone/configs-typescript": "workspace:*",
    "@devstone/easel": "workspace:*",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "commitlint": "20.5.3",
    "eslint": "10.2.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "jiti": "2.6.1",
    "knip": "6.14.0",
    "lefthook": "2.1.6",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.1",
    "oxfmt": "0.47.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@11.1.2"
}
