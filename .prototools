act = "0.2.89"
actionlint = "1.7.12"
bun = "1.3.14"
moon = "2.3.0"
node = "26.3.0"
npm = "11.16.0"
pnpm = "11.5.1"
python = "3.14.5"

[plugins.tools]
act = "https://raw.githubusercontent.com/theomessin/proto-toml-plugins/master/act.toml"
