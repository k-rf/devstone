act = "0.2.82"
actionlint = "1.7.9"
bun = "1.3.13"
moon = "2.2.3"
node = "24.15.0"
npm = "11.13.0"
pnpm = "11.1.2"
python = "3.14.4"

[plugins.tools]
act = "https://raw.githubusercontent.com/theomessin/proto-toml-plugins/master/act.toml"
actionlint = "https://raw.githubusercontent.com/Phault/proto-toml-plugins/main/actionlint/plugin.toml"

[tools.npm]
shared-globals-dir = true

[settings]
auto-install = true
