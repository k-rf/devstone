{
  "context": {
    "fileName": "AGENTS.md"
  },
  "mcpServers": {
    "notion-developers": {
      "serverURL": "https://developers.notion.com/mcp"
    }
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "format-and-lint",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/format-and-lint.sh",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
