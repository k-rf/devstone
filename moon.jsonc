{
  "$schema": ".moon/cache/schemas/project.json",

  "tasks": {
    "format": {
      "description": "コードをoxfmtで整形します。",
      "command": "pnpm run format",
      "options": { "cache": false }
    },
    "knip": {
      "description": "未使用のファイル、エクスポート、依存関係を検出します。",
      "command": "pnpm run knip",
      "options": { "cache": false }
    },
    "test": {
      "command": "noop"
    }
  }
}
